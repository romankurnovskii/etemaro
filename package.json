{
  "name": "dlmm-agent",
  "version": "2.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora on Solana",
  "main": "packages/daemon/dist/Daemon.js",
  "bin": {
    "meridian": "packages/cli/dist/Cli.js"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "start": "node --import tsx packages/daemon/src/Daemon.ts",
    "dev": "DRY_RUN=true node --import tsx packages/daemon/src/Daemon.ts",
    "cli": "node --import tsx packages/cli/src/Cli.ts",
    "setup": "node --import tsx packages/cli/src/Cli.ts setup",
    "balance": "node --import tsx packages/cli/src/Cli.ts balance",
    "positions": "node --import tsx packages/cli/src/Cli.ts positions",
    "candidates": "node --import tsx packages/cli/src/Cli.ts candidates",
    "screen": "node --import tsx packages/cli/src/Cli.ts screen",
    "manage": "node --import tsx packages/cli/src/Cli.ts manage",
    "performance": "node --import tsx packages/cli/src/Cli.ts performance",
    "evolve": "node --import tsx packages/cli/src/Cli.ts evolve",
    "blacklist": "node --import tsx packages/cli/src/Cli.ts blacklist",
    "lessons": "node --import tsx packages/cli/src/Cli.ts lessons",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm -r run typecheck",
    "pm2:start": "pm2 start config/ecosystem.config.cjs",
    "pm2:restart": "pm2 restart meridian --update-env",
    "pm2:logs": "pm2 logs meridian --lines 100",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "knip": {
    "ignore": [
      "discord-listener/**",
      "dist/**"
    ]
  },
  "lint-staged": {
    "*": "pnpm typecheck"
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/web3.js": "^1.95.0",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0",
    "zod": "^3.24.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "**/*.{json,md,html,css,sh}": [
      "prettier --write"
    ]
  }
}